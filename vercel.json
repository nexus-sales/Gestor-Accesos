{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "publickey-credentials-create=(self), publickey-credentials-get=(self)"
        }
      ]
    }
  ]
}
